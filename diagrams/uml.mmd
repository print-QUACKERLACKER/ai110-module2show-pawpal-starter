classDiagram
    %% PawPal+ domain model
    %% Track care tasks, consider constraints, produce & explain a daily plan.
    %% Keep this file updated so it matches your final implementation.

    class Owner {
        +str name
        +list~str~ preferences
        +time day_start
        +time day_end
        +int available_minutes
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
    }

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Task {
        +str title
        +TaskType category
        +int duration_minutes
        +Priority priority
        +time preferred_time
        +bool completed
        +priority_score() int
    }

    class TaskType {
        <<enumeration>>
        WALK
        FEEDING
        MEDS
        ENRICHMENT
        GROOMING
        OTHER
    }

    class ScheduledTask {
        +Task task
        +time start_time
        +time end_time
        +str reason
    }

    class DailyPlan {
        +date plan_date
        +list~ScheduledTask~ entries
        +list~Task~ skipped
        +int total_minutes
        +add_entry(entry ScheduledTask) void
        +explanation() str
    }

    class Scheduler {
        +Owner owner
        +sort_tasks(tasks list~Task~) list~Task~
        +fits(task Task, remaining int) bool
        +build_plan(pet Pet, tasks list~Task~) DailyPlan
        +explain(plan DailyPlan) str
    }

    Owner "1" --> "*" Pet : cares for
    Pet "1" --> "*" Task : has
    Task --> Priority : uses
    Task --> TaskType : categorized by
    Scheduler --> Owner : reads constraints
    Scheduler ..> Task : orders & filters
    Scheduler --> DailyPlan : produces
    DailyPlan "1" --> "*" ScheduledTask : contains
    ScheduledTask --> Task : wraps
